<script type="text/babel">
const { useState, useRef, useCallback } = React;

// в”Ђв”Ђ HELPERS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

function to24h(h, min, sec, mer) {
  let hour = parseInt(h);
  const m = (mer || "").toLowerCase().replace(/[\s.]/g, "");
  if (m.startsWith("p") && hour !== 12) hour += 12;
  if (m.startsWith("a") && hour === 12) hour = 0;
  return { hour, timeStr: `${String(hour).padStart(2,"0")}:${min}:${sec||"00"}` };
}

function parseTurno(h) {
  if (h >= 6 && h < 14) return "1T";
  if (h >= 14 && h < 22) return "2T";
  return "3T";
}

function parseWhatsApp(txt) {
  const lines = txt.split(/\r?\n/);
  const msgs = [];
  // Format A: [DD/MM/YY, H:MM:SS a.m.] Name: text
  const reA = /^\[(\d{1,2})\/(\d{1,2})\/(\d{2,4}),\s*(\d{1,2}):(\d{2})(?::(\d{2}))?\s*(a\.?m\.?|p\.?m\.?)?\]\s*([^:]+?):\s*(.*)$/i;
  // Format B: DD/MM/YYYY, HH:MM - Name: text
  const reB = /^(\d{1,2})\/(\d{1,2})\/(\d{2,4}),\s*(\d{1,2}):(\d{2})(?::(\d{2}))?\s*(AM|PM|a\.m\.|p\.m\.)?\s*[-вЂ“]\s*([^:]+?):\s*(.*)$/i;
  let cur = null;
  for (const raw of lines) {
    const line = raw.replace(/[\u200e\u200f\u202a-\u202eвЂЋ]/g, "").trim();
    const m = line.match(reA) || line.match(reB);
    if (m) {
      if (cur) msgs.push(cur);
      const [, d, mo, yr, h, min, sec, mer, sender, text] = m;
      let year = parseInt(yr); if (year < 100) year += 2000;
      const { hour, timeStr } = to24h(h, min, sec, mer || "");
      const dateIso = `${year}-${String(mo).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
      const dateDisp = `${String(d).padStart(2,"0")}/${String(mo).padStart(2,"0")}/${year}`;
      cur = { dateIso, dateDisp, timeStr, hour, turno: parseTurno(hour), sender: sender.replace(/^~/,"").trim(), text: text.trim() };
    } else if (cur && line && !line.startsWith("[")) {
      cur.text += " " + line;
    }
  }
  if (cur) msgs.push(cur);
  return msgs;
}

function filterByDays(msgs, days) {
  if (!msgs.length) return msgs;
  const sorted = [...msgs].sort((a,b) => a.dateIso.localeCompare(b.dateIso));
  const last = new Date(sorted[sorted.length-1].dateIso);
  const cutoff = new Date(last);
  cutoff.setDate(cutoff.getDate() - days + 1);
  const cutStr = cutoff.toISOString().slice(0,10);
  return sorted.filter(m => m.dateIso >= cutStr);
}

function cleanMsgs(msgs) {
  const skip = /imagen omitida|sticker omitido|audio omitido|video omitido|gif omitido|documento omitido|Se te aГ±adiГі|creГі este grupo|cifrados de extremo|agregГі a|saliГі del grupo|cambiГі el (Г­cono|asunto|nГєmero)|ahora es admin|<Se editГі este mensaje>/i;
  return msgs.filter(m => m.text && m.text.trim().length > 5 && !m.text.match(skip));
}

async function readZip(file) {
  const zip = await JSZip.loadAsync(file);
  for (const name of Object.keys(zip.files)) {
    if (name.endsWith(".txt") && !name.startsWith("__MACOSX")) {
      return await zip.files[name].async("string");
    }
  }
  throw new Error("No se encontrГі archivo .txt dentro del ZIP. Verifica que sea una exportaciГіn de WhatsApp.");
}

async function analyzeWithAI(msgs, apiKey) {
  // Limit to 250 msgs to stay well within token budget and avoid truncated JSON
  const sample = msgs.slice(0, 250).map(m =>
    `[${m.dateDisp} ${m.timeStr} | ${m.turno} | ${m.sender}]: ${m.text}`
  ).join("\n");

  const system = `Eres experto en manufactura electrГіnica SMT/PCB/PTH. Analiza mensajes de grupos de WhatsApp de manufactura y extrae SOLO los eventos operativos accionables.

INCLUIR: paros de lГ­nea, rechazos/defectos de calidad, equivocados de componente, cambios de modelo, problemas de FAI, LCR vencido, falta de material, rollo mal cargado, RMA, problemas de AOI/ICT, alertas de seguridad, llenado de barril bajo, inversiГіn de componentes, ausentes en AOI, cortos, abiertos, daГ±o fГ­sico, problemas de escГЎner/sistema, desabasto, clonados.
EXCLUIR: saludos, "ok", "gracias", "buen dГ­a", confirmaciones simples sin evento, menciones puras sin descripciГіn, mensajes vacГ­os, emojis solos.

Genera un JSON vГЎlido con esta estructura EXACTA (sin markdown, sin texto extra):
{
  "eventos": [
    {
      "id": "EVT-001",
      "fecha": "DD/MM/YYYY",
      "hora": "HH:MM",
      "turno": "1T|2T|3T",
      "modelo": "nГєmero de parte o N/D",
      "linea_estacion": "L1|L2|AOI|ICT|etc o N/D",
      "reporta": "nombre",
      "area_involucrada": "SMT|PTH|ICT|AOI|Kitting|Calidad|Mantenimiento|IT|etc",
      "tipo_evento": "categorГ­a corta del evento",
      "evento_detectado": "descripciГіn clara y completa del evento en espaГ±ol",
      "impacto": "impacto operativo concreto",
      "accion_requerida": "acciГіn especГ­fica a tomar",
      "responsable_sugerido": "ГЎrea o persona responsable",
      "estatus": "Abierto|En proceso|Cerrado",
      "prioridad": "CrГ­tica|Alta|Media|Baja",
      "fuente_chat": "DD/MM/YY HH:MM remitente",
      "notas": "contexto adicional relevante"
    }
  ],
  "kpis": [
    { "fechahora": "DD/MM/YYYY HH:MM", "indicador": "nombre del KPI", "valor": 0.0, "unidad": "%|pzas|etc", "fuente": "remitente" }
  ],
  "resumen": {
    "periodo": "DD/MM/YYYY a DD/MM/YYYY",
    "grupo": "nombre del grupo de chat",
    "total_eventos": 0,
    "alertas_criticas": ["mГЎx 5 alertas crГ­ticas abiertas"],
    "acciones_pendientes": ["mГЎx 5 acciones prioritarias pendientes"],
    "estatus_lineas": ["estado de lГ­neas con actividad relevante"]
  }
}`;

  const resp = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json", "x-api-key": apiKey, "anthropic-version": "2023-06-01", "anthropic-dangerous-direct-browser-access": "true" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 6000,
      system,
      messages: [
        { role: "user", content: `Analiza estos ${msgs.length} mensajes del grupo de manufactura. Responde ГљNICAMENTE con el JSON, sin texto antes ni despuГ©s:\n\n${sample}` },
        { role: "assistant", content: "{" }
      ]
    })
  });
  if (!resp.ok) {
    const err = await resp.json().catch(()=>({}));
    const msg = err.error?.message || `Error API ${resp.status}`;
    if (resp.status === 401) throw new Error("API Key invГЎlida. Verifica tu clave en console.anthropic.com");
    if (resp.status === 429) throw new Error("LГ­mite de uso alcanzado. Espera un momento e intenta de nuevo.");
    throw new Error(msg);
  }
  const data = await resp.json();
  if (!data.content?.length) throw new Error("Respuesta vacГ­a de la API. Intenta de nuevo.");
  const txt = "{" + data.content.map(b => b.text || "").join("");
  // Robust JSON extraction: strip markdown fences, find outermost { }
  const stripped = txt.replace(/```json\s*/gi, "").replace(/```\s*/g, "").trim();
  const start = stripped.indexOf("{");
  const end = stripped.lastIndexOf("}");
  if (start === -1 || end === -1) throw new Error("La IA no devolviГі JSON vГЎlido. Intenta de nuevo o reduce el rango de dГ­as.");
  const jsonStr = stripped.slice(start, end + 1);
  try {
    return JSON.parse(jsonStr);
  } catch(parseErr) {
    // Try to salvage truncated JSON by closing open structures
    const fixed = jsonStr
      .replace(/,\s*$/, "")           // trailing comma
      .replace(/,\s*\]/, "]")          // trailing comma in array
      .replace(/,\s*\}/, "}")          // trailing comma in object
      + (jsonStr.split("{").length > jsonStr.split("}").length ? "}" : "")
      + (jsonStr.split("[").length > jsonStr.split("]").length ? "]}" : "");
    try {
      return JSON.parse(fixed);
    } catch {
      throw new Error("Error al procesar la respuesta. Intenta con menos dГ­as (1 o 3) para reducir el tamaГ±o.");
    }
  }
}

function buildXlsx(result) {
  const wb = XLSX.utils.book_new();
  const ev = result.eventos || [];
  const kpis = result.kpis || [];
  const res = result.resumen || {};

  const H = ["ID","Fecha","Hora","Turno","Modelo","Linea_Estacion","Reporta","Area_involucrada","Tipo_evento","Evento_detectado","Impacto","Accion_requerida","Responsable_sugerido","Estatus","Prioridad","Fuente_chat","Notas"];
  const row = e => [e.id,e.fecha,e.hora,e.turno,e.modelo,e.linea_estacion,e.reporta,e.area_involucrada,e.tipo_evento,e.evento_detectado,e.impacto,e.accion_requerida,e.responsable_sugerido,e.estatus,e.prioridad,e.fuente_chat,e.notas];

  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([H,...ev.map(row)]), "Bitacora");
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([H,...ev.filter(e=>e.estatus!=="Cerrado").map(row)]), "Pendientes");
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([["FechaHora","Indicador","Valor","Unidad","Fuente_chat"],...kpis.map(k=>[k.fechahora,k.indicador,k.valor,k.unidad,k.fuente])]), "KPIs_chat");

  const ab = ev.filter(e=>e.estatus==="Abierto").length;
  const ep = ev.filter(e=>e.estatus==="En proceso").length;
  const ce = ev.filter(e=>e.estatus==="Cerrado").length;
  const cr = ev.filter(e=>e.prioridad==="CrГ­tica"&&e.estatus!=="Cerrado").length;
  const mods = [...new Set(ev.map(e=>e.modelo).filter(Boolean))];

  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([
    ["Resumen ejecutivo de manufactura"],["Periodo",res.periodo||""],["Grupo",res.grupo||""],[]  ,
    ["=== ESTATUS POR LГЌNEA ==="],...(res.estatus_lineas||[]).map(l=>["- "+l]),[],
    ["=== ALERTAS CRГЌTICAS ==="],...(res.alertas_criticas||[]).map(a=>["- "+a]),[],
    ["=== ACCIONES PENDIENTES ==="],...(res.acciones_pendientes||[]).map(a=>["- "+a]),[],
    ["=== KPIs ==="],...kpis.map(k=>[k.indicador,k.valor,k.unidad,k.fechahora]),[],
    ["=== RESUMEN ==="],["Total eventos",ev.length],["Abiertos",ab],["En proceso",ep],["Cerrados",ce],["CrГ­ticos activos",cr],
  ]), "Resumen_Junta");

  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([
    ["Dashboard base"],[],["KPI","Valor"],
    ["Total eventos",ev.length],["Abiertos",ab],["En proceso",ep],["Cerrados",ce],["CrГ­ticos activos",cr],[],
    ["Por modelo",""],...mods.map(m=>["Eventos "+m,ev.filter(e=>e.modelo===m).length]),
  ]), "Dashboard_Base");

  const lins = [...new Set(ev.map(e=>e.linea_estacion).filter(Boolean))];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet([
    ["CatГЎlogos detectados"],[],["Modelos","","LГ­neas / Estaciones"],
    ...[...Array(Math.max(mods.length,lins.length))].map((_,i)=>[mods[i]||"","",lins[i]||""]),
  ]), "Catalogos_Reglas");

  return XLSX.write(wb, { bookType:"xlsx", type:"array" });
}

